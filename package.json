{
  "name": "sfi-gec-palakkad",
  "version": "2.0.0",
  "description": "SFI GEC Palakkad - Study Companion Portal with Sahayi",
  "main": "index.html",
  "scripts": {
    "start": "npx live-server . --port=3000 --open=./index.html",
    "dev": "npx live-server . --port=3000",
    "build": "npm run minify:css && npm run minify:js && echo 'Build complete!'",
    "minify:css": "npx clean-css-cli -o assets/css/main.min.css assets/css/main.css",
    "minify:js": "npx terser assets/js/main.js -o assets/js/main.min.js -c -m",
    "optimize:images": "npx imagemin assets/img --out-dir=assets/img"
  },
  "keywords": [
    "study-notes",
    "question-papers",
    "scholarships",
    "gec-palakkad",
    "sahayi",
    "study-companion"
  ],
  "author": "SFI GEC Palakkad",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sfigecpalakkad/SFIGECP.git"
  },
  "devDependencies": {
    "live-server": "^1.2.2"
  }
}